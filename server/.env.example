PORT=5050
NODE_ENV=development

# MongoDB Atlas URI (include db name)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/studenthub?retryWrites=true&w=majority

# Use a strong random secret (at least 32 chars in production)
JWT_SECRET=<replace-with-long-random-secret>
JWT_EXPIRES_IN=7d

# Frontend origin and optional comma-separated allowlist
CLIENT_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional security tuning
MAX_INPUT_LENGTH=5000
EMAIL_SEND_TIMEOUT_MS=12000
SMTP_TIMEOUT_MS=10000

# App features
SUPER_ADMIN_EMAIL=admin@example.com
GOOGLE_CLIENT_ID=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Legacy aliases also supported: EMAIL_USER, EMAIL_PASS, EMAIL_FROM
# For Gmail app password, paste the 16-char value (spaces are optional).
SMTP_SERVICE=gmail
# Optional explicit SMTP host override (leave blank to use SMTP_SERVICE defaults)
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=